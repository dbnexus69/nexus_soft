// =========================================================
// COMISIONES Y LIQUIDACIONES
// =========================================================

model LiquidacionesComision {
  id              Int           @id @default(autoincrement())
  comisionistaId  Int           @map("comisionista_id")
  comisionista    Comisionistas @relation(fields: [comisionistaId], references: [id])
  fecha           DateTime
  monto           Float
  metodoPagoId    Int?          @map("metodo_pago_id")
  metodoPago      MetodosPago?  @relation(fields: [metodoPagoId], references: [id])
  referencia      String?
  notas           String?
  creadoAt        DateTime      @default(now()) @map("creado_at")

  liquidacionVentas LiquidacionVentas[]

  @@map("liquidaciones_comision")
}

model LiquidacionVentas {
  id             Int      @id @default(autoincrement())
  liquidacionId  Int      @map("liquidacion_id")
  liquidacion    LiquidacionesComision @relation(fields: [liquidacionId], references: [id])
  ventaId        Int      @map("venta_id")
  venta          Ventas   @relation(fields: [ventaId], references: [id])

  @@unique([liquidacionId, ventaId])
  @@map("liquidacion_ventas")
}

// =========================================================
// VENTAS MENSUALES (para historial/stats)
// =========================================================

model VentasMensuales {
  id          Int    @id @default(autoincrement())
  year        Int
  month       Int
  total       Float
  count       Int
  hoteles     Float?
  vuelos      Float?
  paquetes    Float?
  seguros     Float?
  transferencias Float?

  @@unique([year, month])
  @@map("ventas_mensuales")
}
