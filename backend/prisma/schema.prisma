generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "foreignKeys"
}

model aerolineas {
  id                 Int                  @id @default(autoincrement())
  nombre             String
  codigo_iata        String?              @unique
  tipo               Cobertura            @default(Internacional)
  web                String?
  paquete_vuelo      paquete_vuelo[]
  politicas_equipaje politicas_equipaje[]
  prod_planes        prod_planes[]
  prod_tiqueteria    prod_tiqueteria[]
  tramos_vuelo       tramos_vuelo[]
}

model aeropuertos {
  id                                                           Int            @id @default(autoincrement())
  nombre                                                       String
  codigo_iata                                                  String         @unique
  ciudad                                                       String?
  pais                                                         String?
  tipo                                                         Cobertura      @default(Ambos)
  status                                                       UserStatus     @default(active)
  tramos_vuelo_tramos_vuelo_aeropuerto_destino_idToaeropuertos tramos_vuelo[] @relation("tramos_vuelo_aeropuerto_destino_idToaeropuertos")
  tramos_vuelo_tramos_vuelo_aeropuerto_origen_idToaeropuertos  tramos_vuelo[] @relation("tramos_vuelo_aeropuerto_origen_idToaeropuertos")
}

model clientes {
  id             Int       @id @default(autoincrement())
  persona_id     Int       @unique
  creado_por_id  Int?
  fecha_registro DateTime  @default(now())
  deleted_at     DateTime?
  usuarios       usuarios? @relation(fields: [creado_por_id], references: [id])
  personas       personas  @relation(fields: [persona_id], references: [id])
  ventas         ventas[]
}

model comisionistas {
  id                     Int                      @id @default(autoincrement())
  persona_id             Int                      @unique
  tipo                   String?
  umbral_pago            Float?                   @default(0)
  acumulado              Float?                   @default(0)
  status                 AgentStatus              @default(Activo)
  creado_at              DateTime                 @default(now())
  personas               personas                 @relation(fields: [persona_id], references: [id])
  liquidaciones_comision liquidaciones_comision[]
  ventas                 ventas[]
}

model detalle_venta {
  id                       String              @id
  venta_id                 Int
  categoria                String
  nombre_servicio          String?
  subtotal                 Float?              @default(0)
  ta                       Float?              @default(0)
  costo_proveedor          Float?              @default(0)
  proveedor_id             Int?
  metodo_pago_proveedor_id Int?
  voucher_url              String?
  fecha_inicio_viaje       DateTime?
  fecha_fin_viaje          DateTime?
  origen                   String?
  destino                  String?
  observaciones            String?
  creado_at                DateTime?           @default(now())
  parentDetalleId          String?             @map("parent_detalle_id")
  metodos_pago             metodos_pago?       @relation(fields: [metodo_pago_proveedor_id], references: [id])
  proveedores              proveedores?        @relation(fields: [proveedor_id], references: [id])
  ventas                   ventas              @relation(fields: [venta_id], references: [id])
  parentDetalle            detalle_venta?      @relation("DetalleVentaHierarchy", fields: [parentDetalleId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  childDetalles            detalle_venta[]     @relation("DetalleVentaHierarchy")
  pasajeros_detalle        pasajeros_detalle[]
  prod_autos               prod_autos?
  prod_checkins            prod_checkins?
  prod_eventos             prod_eventos?
  prod_fincas              prod_fincas?
  prod_hoteleria           prod_hoteleria?
  prod_mascotas            prod_mascotas?
  prod_migracion           prod_migracion?
  prod_pasaportes          prod_pasaportes?
  prod_planes              prod_planes?
  prod_restaurantes        prod_restaurantes?
  prod_seguros             prod_seguros?
  prod_simcards            prod_simcards?
  prod_tiqueteria          prod_tiqueteria?
  prod_tours               prod_tours?
  prod_visas               prod_visas?

  @@index([metodo_pago_proveedor_id])
  @@index([proveedor_id])
  @@index([venta_id])
}

model liquidacion_ventas {
  id                     Int                    @id @default(autoincrement())
  liquidacion_id         Int
  venta_id               Int
  liquidaciones_comision liquidaciones_comision @relation(fields: [liquidacion_id], references: [id])
  ventas                 ventas                 @relation(fields: [venta_id], references: [id])

  @@unique([liquidacion_id, venta_id])
}

model liquidaciones_comision {
  id                 Int                  @id @default(autoincrement())
  comisionista_id    Int
  fecha              DateTime
  monto              Float
  metodo_pago_id     Int?
  referencia         String?
  notas              String?
  creado_at          DateTime             @default(now())
  liquidacion_ventas liquidacion_ventas[]
  comisionistas      comisionistas        @relation(fields: [comisionista_id], references: [id])
  metodos_pago       metodos_pago?        @relation(fields: [metodo_pago_id], references: [id])
}

model logs_usuarios {
  id          Int      @id @default(autoincrement())
  usuario_id  Int
  accion      String?
  modulo      String?
  descripcion String?
  fecha       DateTime @default(now())
  usuarios    usuarios @relation(fields: [usuario_id], references: [id])
}

model metodos_pago {
  id                     Int                      @id @default(autoincrement())
  nombre                 String                   @unique
  detalle_venta          detalle_venta[]
  liquidaciones_comision liquidaciones_comision[]
  pagos_venta            pagos_venta[]
  tarjetas_agencia       tarjetas_agencia[]
  ventas                 ventas[]
}

model pagos_venta {
  id             String        @id
  venta_id       Int
  monto          Float
  metodo_pago_id Int?
  referencia     String?
  fecha_pago     DateTime      @default(now())
  metodos_pago   metodos_pago? @relation(fields: [metodo_pago_id], references: [id])
  ventas         ventas        @relation(fields: [venta_id], references: [id])

  @@index([venta_id])
}

model paquete_asistencia_medica {
  id             Int      @id @default(autoincrement())
  paquete_id     Int      @unique
  cobertura_usd  Float    @default(0)
  dias_cobertura Int      @default(0)
  paquetes       paquetes @relation(fields: [paquete_id], references: [id])
}

model paquete_hotel {
  id           Int                 @id @default(autoincrement())
  paquete_id   Int
  hotel_nombre String
  tipo_hotel   TipoHotel?          @default(hotel)
  regimen      RegimenAlimenticio? @default(full)
  noches       Int?
  paquetes     paquetes            @relation(fields: [paquete_id], references: [id])
}

model paquete_proveedor {
  id           Int         @id @default(autoincrement())
  paquete_id   Int
  proveedor_id Int
  paquetes     paquetes    @relation(fields: [paquete_id], references: [id])
  proveedores  proveedores @relation(fields: [proveedor_id], references: [id])
}

model paquete_tarifas {
  id             Int           @id @default(autoincrement())
  paquete_id     Int
  tarifa_adulto  Float         @default(0)
  tarifa_menor   Float?
  vigencia_desde DateTime?
  vigencia_hasta DateTime?
  paquetes       paquetes      @relation(fields: [paquete_id], references: [id])
  prod_planes    prod_planes[]
}

model paquete_vuelo {
  id              Int         @id @default(autoincrement())
  paquete_id      Int
  aerolinea_id    Int?
  nro_vuelo       String?
  modo_vuelo      FlightMode? @default(round_trip)
  trayectos       Json?
  plan_equipaje   String?
  tipo_transporte String?     @default("Aereo")
  aerolineas      aerolineas? @relation(fields: [aerolinea_id], references: [id])
  paquetes        paquetes    @relation(fields: [paquete_id], references: [id])
}

model paquetes {
  id                        Int                        @id @default(autoincrement())
  nombre                    String
  destino                   String
  servicios_incluidos       String?
  no_incluido               String?
  status                    EstadoPaquete              @default(activo)
  creado_por_id             Int?
  creado_at                 DateTime                   @default(now())
  deleted_at                DateTime?
  paquete_asistencia_medica paquete_asistencia_medica?
  paquete_hotel             paquete_hotel[]
  paquete_proveedor         paquete_proveedor[]
  paquete_tarifas           paquete_tarifas[]
  paquete_vuelo             paquete_vuelo[]
  usuarios                  usuarios?                  @relation(fields: [creado_por_id], references: [id])
  prod_planes               prod_planes[]
}

model pasajeros_detalle {
  id               String        @id
  detalle_venta_id String
  persona_id       Int
  es_titular       Boolean?      @default(false)
  asiento          String?
  nro_reserva      String?
  nro_tiquete      String?
  nota             String?
  detalle_venta    detalle_venta @relation(fields: [detalle_venta_id], references: [id])
  personas         personas      @relation(fields: [persona_id], references: [id])

  @@index([detalle_venta_id])
  @@index([persona_id])
}

model permisos {
  id               Int                @id @default(autoincrement())
  modulo           String
  accion           String
  descripcion      String?
  permisos_rol     permisos_rol[]
  permisos_usuario permisos_usuario[]
}

model permisos_rol {
  id         Int      @id @default(autoincrement())
  rol_id     Int
  permiso_id Int
  valor      String   @default("true")
  permisos   permisos @relation(fields: [permiso_id], references: [id])
  roles      roles    @relation(fields: [rol_id], references: [id])

  @@unique([rol_id, permiso_id])
}

model permisos_usuario {
  id         Int      @id @default(autoincrement())
  usuario_id Int
  permiso_id Int
  permitido  Boolean  @default(true)
  valor      String   @default("true")
  permisos   permisos @relation(fields: [permiso_id], references: [id])
  usuarios   usuarios @relation(fields: [usuario_id], references: [id])

  @@unique([usuario_id, permiso_id])
}

model personas {
  id                Int                 @id @default(autoincrement())
  nombres           String
  apellidos         String
  tipo_documento_id Int?
  documento         String?             @unique
  email             String?
  telefono          String?
  birth_date        DateTime?
  nacionalidad      String?
  avatar_url        String?
  status            UserStatus          @default(active)
  creado_at         DateTime            @default(now())
  updated_at        DateTime?
  deleted_at        DateTime?
  clientes          clientes?
  comisionistas     comisionistas?
  pasajeros_detalle pasajeros_detalle[]
  tipos_documento   tipos_documento?    @relation(fields: [tipo_documento_id], references: [id])
  responsables      responsables?
  usuarios          usuarios?
}

model politicas_equipaje {
  id                Int               @id @default(autoincrement())
  aerolinea_id      Int
  tipo_tarifa       String
  articulo_personal String?
  equipaje_mano     String?
  equipaje_bodega   String?
  notas             String?
  aerolineas        aerolineas        @relation(fields: [aerolinea_id], references: [id])
  prod_tiqueteria   prod_tiqueteria[]
  tramos_vuelo      tramos_vuelo[]
}

model prod_autos {
  id                      String        @id
  detalle_venta_id        String        @unique
  conductor_nombre        String?
  licencia_nro            String?
  fecha_recogida          DateTime?
  fecha_devolucion        DateTime?
  lugar_recogida          String?
  categoria_auto          String?
  conductores_adicionales Int?          @default(0)
  tipo_seguro             String?
  tarjeta_garantia_info   String?
  detalle_venta           detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_checkins {
  id                     String        @id
  detalle_venta_id       String        @unique
  nro_vuelo_reserva      String?
  fecha_viaje            DateTime?
  asiento                String?
  maletas_contadas       String?
  telefono_contacto      String?
  necesidades_especiales String?
  usa_silla_ruedas       Boolean?      @default(false)
  detalle_venta          detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_eventos {
  id                  String        @id
  detalle_venta_id    String        @unique
  organizacion        String?
  nombre_contacto     String?
  email_contacto      String?
  fechaInicio         DateTime?
  fechaFin            DateTime?
  asistencia_estimada Int?
  espacio_requerido   String?
  tipo_evento         String?
  equipos_av          String?
  requiere_catering   Boolean?      @default(false)
  notas_catering      String?
  ciudad              String?       @db.VarChar(40)
  direccion           String?       @db.VarChar(40)
  nombre_lugar        String?       @db.VarChar(40)
  detalle_venta       detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_fincas {
  id                    String        @id
  detalle_venta_id      String        @unique
  responsable_nombre    String?
  documento_responsable String?
  fecha_entrada         DateTime?
  fecha_salida          DateTime?
  adultos_count         Int?
  ninos_count           Int?
  tiene_mascotas        Boolean?      @default(false)
  tipo_mascota          String?
  servicios_extra       String?
  nombre_finca          String?
  direccion_finca       String?
  ciudad_pueblo         String?
  observaciones         String?
  detalle_venta         detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_hoteleria {
  id               String        @id
  detalle_venta_id String        @unique
  hotel_nombre     String?
  tipo_hotel       TipoHotel?    @default(hotel)
  destino          String?
  nro_reserva      String?
  fecha_entrada    DateTime?
  fecha_salida     DateTime?
  observaciones    String?
  detalle_venta    detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_mascotas {
  id                  String         @id
  detalle_venta_id    String         @unique
  mascota_nombre      String?
  especie             String?
  raza                String?
  peso_kg             Float?
  tamanoMascota       TamanoMascota?
  transporte_tipo     String?
  fecha_viaje         DateTime?
  pais_destino        String?
  condiciones_medicas String?
  telefono_contacto   String?
  empresa_transporte  String?
  observaciones       String?
  detalle_venta       detalle_venta  @relation(fields: [detalle_venta_id], references: [id])
}

model prod_migracion {
  id                      String        @id
  detalle_venta_id        String        @unique
  tipo_tramite_migratorio String?
  nacionalidad            String?
  tipo_documento          String?       @default("Pasaporte")
  pasaporte_nro           String?
  pasaporte_vence         DateTime?
  pais_destino            String?
  detalle_venta           detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_pasaportes {
  id                   String        @id
  detalle_venta_id     String        @unique
  nombre_completo      String?
  nro_documento        String?
  fecha_nacimiento     DateTime?
  ciudad_residencia    String?
  tipo_tramite         String?
  fecha_estimada_viaje DateTime?
  telefono_contacto    String?
  detalle_venta        detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_planes {
  id                          String           @id
  detalle_venta_id            String           @unique
  paqueteId                   Int?
  paquete_tarifa_id           Int?
  nombre_plan                 String?
  nombre_hotel                String?
  aerolineaId                 Int?
  nro_vuelo                   String?
  nro_reserva                 String?
  nro_tiquete                 String?
  fecha_viaje_inicio          DateTime?
  fecha_viaje_fin             DateTime?
  fecha_salida_vuelo          DateTime?
  fecha_llegada_vuelo         DateTime?
  fecha_regreso_vuelo         DateTime?
  fecha_llegada_regreso_vuelo DateTime?
  adultos_count               Int?
  menores_count               Int?
  numero_confirmacion         String?
  observaciones               String?
  checkin_status_ida          CheckinStatus?   @default(pendiente)
  checkin_status_regreso      CheckinStatus?   @default(pendiente)
  tipo_paquete                String?          @default("own")
  tipo_transporte             String?          @default("Aereo")
  aerolineas                  aerolineas?      @relation(fields: [aerolineaId], references: [id])
  detalle_venta               detalle_venta    @relation(fields: [detalle_venta_id], references: [id])
  paquetes                    paquetes?        @relation(fields: [paqueteId], references: [id])
  paquete_tarifas             paquete_tarifas? @relation(fields: [paquete_tarifa_id], references: [id])
}

model prod_restaurantes {
  id                  String        @id
  detalle_venta_id    String        @unique
  nombre_reserva      String?
  fecha_hora_reserva  DateTime?
  personas_count      Int?
  preferencia_mesa    String?
  tipo_menu           String?
  restricciones_dieta String?
  ocasion_especial    String?
  telefono_contacto   String?
  detalle_venta       detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_seguros {
  id                    String        @id
  detalle_venta_id      String        @unique
  tipo_seguro           String?
  cobertura_usd         Float?        @default(0)
  dias_cobertura        Int?          @default(0)
  fecha_inicio_vigencia DateTime?
  fecha_fin_vigencia    DateTime?
  telefono_contacto     String?
  detalle_venta         detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_simcards {
  id               String        @id
  detalle_venta_id String        @unique
  pais_destino     String?
  fecha_llegada    DateTime?
  duracion_viaje   String?
  plan_datos       String?
  tipo_sim         String?
  metodo_entrega   String?
  detalle_venta    detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_tiqueteria {
  id                 String              @id
  detalle_venta_id   String              @unique
  aerolineaId        Int?
  nro_reserva        String?
  nro_vuelo          String?
  nro_tiquete        String?
  modo_vuelo         FlightMode?         @default(one_way)
  planEquipajeId     Int?
  checkin_status     CheckinStatus?      @default(pendiente)
  aerolineas         aerolineas?         @relation(fields: [aerolineaId], references: [id])
  detalle_venta      detalle_venta       @relation(fields: [detalle_venta_id], references: [id])
  politicas_equipaje politicas_equipaje? @relation(fields: [planEquipajeId], references: [id])
  tramos_vuelo       tramos_vuelo[]
}

model prod_tours {
  id                  String        @id
  detalle_venta_id    String        @unique
  tour_nombre         String?
  fecha_preferida     DateTime?
  adultos_count       Int?          @default(1)
  menores_count       Int?          @default(0)
  edades_menores      String?
  idioma_guia         String?
  requiere_transporte Boolean?      @default(false)
  punto_encuentro     String?
  condiciones_medicas String?
  telefono_contacto   String?
  observaciones       String?
  detalle_venta       detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model prod_visas {
  id                    String        @id
  detalle_venta_id      String        @unique
  nombre_completo       String?
  fecha_nacimiento      DateTime?
  nacionalidad          String?
  tipo_documento        String?       @default("Pasaporte")
  nro_pasaporte         String?
  vencimiento_pasaporte DateTime?
  pais_aplicacion       String?
  tipo_visa             String?
  fecha_estimada_viaje  DateTime?
  email_contacto        String?
  detalle_venta         detalle_venta @relation(fields: [detalle_venta_id], references: [id])
}

model proveedores {
  id                Int                 @id @default(autoincrement())
  nombre            String
  tipo              String?
  email_contacto    String?
  telefono          String?
  web               String?
  observaciones     String?
  status            UserStatus          @default(active)
  detalle_venta     detalle_venta[]
  paquete_proveedor paquete_proveedor[]
}

model responsables {
  id         Int        @id @default(autoincrement())
  persona_id Int        @unique
  status     UserStatus @default(active)
  creado_at  DateTime   @default(now())
  deleted_at DateTime?
  personas   personas   @relation(fields: [persona_id], references: [id])
  ventas     ventas[]
}

model roles {
  id           Int            @id @default(autoincrement())
  nombre       String         @unique
  descripcion  String?
  permisos_rol permisos_rol[]
  usuarios     usuarios[]
}

model sesiones {
  id         String   @id
  usuario_id Int
  token_hash String
  expires_at DateTime
  creado_at  DateTime @default(now())
  user_agent String?
  usuarios   usuarios @relation(fields: [usuario_id], references: [id])
}

model tarjetas_agencia {
  id             Int           @id @default(autoincrement())
  nombre         String
  metodo_pago_id Int?
  ultimos_cuatro String?
  descripcion    String?
  status         UserStatus    @default(active)
  creado_at      DateTime      @default(now())
  metodos_pago   metodos_pago? @relation(fields: [metodo_pago_id], references: [id])
}

model tipos_documento {
  id          Int        @id @default(autoincrement())
  nombre      String
  abreviatura String     @unique
  personas    personas[]
}

model tramos_vuelo {
  id                                                          String              @id
  prod_tiqueteria_id                                          String
  aeropuerto_origen_id                                        Int
  aeropuerto_destino_id                                       Int
  salida                                                      DateTime
  llegada                                                     DateTime
  nro_vuelo_tramo                                             String?
  asiento                                                     String?
  orden                                                       Int                 @default(1)
  checkin_status                                              CheckinStatus?      @default(pendiente)
  nro_tiquete                                                 String?
  aerolinea_id                                                Int?
  plan_equipaje_id                                            Int?
  aerolineas                                                  aerolineas?         @relation(fields: [aerolinea_id], references: [id])
  aeropuertos_tramos_vuelo_aeropuerto_destino_idToaeropuertos aeropuertos         @relation("tramos_vuelo_aeropuerto_destino_idToaeropuertos", fields: [aeropuerto_destino_id], references: [id])
  aeropuertos_tramos_vuelo_aeropuerto_origen_idToaeropuertos  aeropuertos         @relation("tramos_vuelo_aeropuerto_origen_idToaeropuertos", fields: [aeropuerto_origen_id], references: [id])
  politicas_equipaje                                          politicas_equipaje? @relation(fields: [plan_equipaje_id], references: [id])
  prod_tiqueteria                                             prod_tiqueteria     @relation(fields: [prod_tiqueteria_id], references: [id])

  @@index([aeropuerto_destino_id])
  @@index([aeropuerto_origen_id])
  @@index([prod_tiqueteria_id])
}

model usuarios {
  id               Int                @id @default(autoincrement())
  persona_id       Int                @unique
  email            String             @unique
  password_hash    String
  rol_id           Int
  status           UserStatus         @default(active)
  ultimo_login     DateTime?
  creado_at        DateTime           @default(now())
  clientes         clientes[]
  logs_usuarios    logs_usuarios[]
  paquetes         paquetes[]
  permisos_usuario permisos_usuario[]
  sesiones         sesiones[]
  personas         personas           @relation(fields: [persona_id], references: [id])
  roles            roles              @relation(fields: [rol_id], references: [id])
  ventas           ventas[]
}

model ventas {
  id                            Int                  @id @default(autoincrement())
  cliente_id                    Int
  usuario_id                    Int
  monto_total                   Float                @default(0)
  costo_proveedor_total         Float?               @default(0)
  ta_total                      Float?               @default(0)
  comisionista_id               Int?
  responsable_id                Int?
  monto_comision_bruto          Float?               @default(0)
  porcentaje_retencion_comision Float?               @default(0)
  monto_comision_neto           Float?               @default(0)
  comision_liquidada            Boolean?             @default(false)
  metodo_pago_principal_id      Int?
  status                        SaleStatus           @default(credito)
  es_credito                    Boolean?             @default(false)
  fecha_vence_credito           DateTime?
  monto_pagado_credito          Float?               @default(0)
  is_reviewed                   Boolean?             @default(false)
  observaciones                 String?
  creado_at                     DateTime             @default(now())
  deleted_at                    DateTime?
  detalle_venta                 detalle_venta[]
  liquidacion_ventas            liquidacion_ventas[]
  pagos_venta                   pagos_venta[]
  clientes                      clientes             @relation(fields: [cliente_id], references: [id])
  comisionistas                 comisionistas?       @relation(fields: [comisionista_id], references: [id])
  metodos_pago                  metodos_pago?        @relation(fields: [metodo_pago_principal_id], references: [id])
  responsables                  responsables?        @relation(fields: [responsable_id], references: [id])
  usuarios                      usuarios             @relation(fields: [usuario_id], references: [id])

  @@index([cliente_id])
  @@index([comisionista_id])
  @@index([usuario_id])
}

model ventas_mensuales {
  id             Int    @id @default(autoincrement())
  year           Int
  month          Int
  total          Float
  count          Int
  hoteles        Float?
  vuelos         Float?
  paquetes       Float?
  seguros        Float?
  transferencias Float?

  @@unique([year, month])
}

enum AgentStatus {
  Activo
  Inactivo
}

enum CheckinStatus {
  pendiente
  realizado
  critico
}

enum Cobertura {
  Nacional
  Internacional
  Ambos
}

enum EstadoPaquete {
  activo
  inactivo
  agotado
}

enum FlightMode {
  one_way
  round_trip
}

enum RegimenAlimenticio {
  solo_desayuno
  media_pension
  todo_incluido
  full
  sin_alimentacion
}

enum SaleStatus {
  credito
  abonado
  pagado
  anulado
}

enum TamanoMascota {
  pequeno
  mediano
  grande
  gigante
}

enum TipoHotel {
  hotel
  resort
  boutique
  apartamento
  hostal
  fincas
}

enum UserStatus {
  active
  inactive
}
